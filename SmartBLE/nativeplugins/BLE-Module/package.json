{
	"name": "BLE-Module",
	"id": "BLE-Module",
	"version": "1.0.0",
	"description": "BLE广播插件，支持自定义广播数据、扫描响应等功能",
	"_dp_type": "nativeplugin",
	"_dp_nativeplugin": {
		"android": {
			"plugins": [{
				"type": "module",
				"name": "BLE_Module",
				"class": "io.dcloud.uniplugin.BLEModule"
			}],
			"permissions": [
				"android.permission.BLUETOOTH",
				"android.permission.BLUETOOTH_ADMIN",
				"android.permission.ACCESS_FINE_LOCATION",
				"android.permission.ACCESS_COARSE_LOCATION",
				"android.permission.BLUETOOTH_ADVERTISE",
				"android.permission.BLUETOOTH_CONNECT",
				"android.permission.BLUETOOTH_SCAN"
			],
			"dependencies": [
				"androidx.appcompat:appcompat:1.6.1"
			],
			"minSdkVersion": "21",
			"integrateType": "aar",
			"useAndroidX": true
		},
		"ios": {
			"capabilities": {
				"bluetooth": {
					"peripheral": true,
					"central": true,
					"backgroundModes": true
				}
			},
			"plugins": [{
				"type": "module",
				"name": "BLE_Module",
				"class": "LuoUniBleCommonObject"
			}],
			"integrateType": "framework",
			"frameworks": ["CoreBluetooth.framework"],
			"capabilities": {
				"entitlements": {
					"com.apple.developer.bluetooth-peripheral": true,
					"com.apple.developer.bluetooth-central": true,
					"com.apple.developer.bluetooth-background-modes": true
				},
				"plists": {
					"NSBluetoothAlwaysUsageDescription": "此应用需要使用蓝牙进行BLE广播",
					"NSBluetoothPeripheralUsageDescription": "此应用需要使用蓝牙进行BLE广播"
				}
			},
			"deploymentTarget": "10.0",
			"validArchitectures": [
				"arm64",
				"arm64e",
				"armv7",
				"armv7s"
			]
		}
	}
}