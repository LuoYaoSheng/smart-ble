<view class="flex flex-column"><view class="item flex flex-column justify-center"><text class="title font-size-list color-text-title">service</text><text class="subtitle font-size-subtitle color-text-subtitle">{{"UUID:"+characteristic.serviceId}}</text></view><view class="item flex flex-column justify-center"><text class="title font-size-list color-text-title">characteristic</text><text class="subtitle font-size-subtitle color-text-subtitle">{{"UUID:"+characteristic.uuid}}</text></view><block wx:if="{{characteristic.properties.notify||characteristic.properties.indicate}}"><view class="flex flex-column"><view class="item-bar flex flex-row justify-between align-center"><text class="font-size-list color-text-title">通知</text><block wx:if="{{notifyState}}"><view data-event-opts="{{[['tap',[['notifyAction']]]]}}" class="item-btn" bindtap="__e">监听中</view></block><block wx:else><view data-event-opts="{{[['tap',[['notifyAction']]]]}}" class="item-btn" bindtap="__e">监听</view></block></view><divider vue-id="48dad621-1" bind:__l="__l"></divider><textarea class="item-content font-size-subtitle" disabled="true" placeholder="通知内容" value="{{notifyText}}"></textarea></view></block><block wx:if="{{characteristic.properties.read}}"><view class="flex flex-column h-spacing-large-top"><view class="item-bar flex flex-row justify-between align-center"><text class="font-size-list color-text-title">读取</text><view data-event-opts="{{[['tap',[['readAction']]]]}}" class="item-btn" bindtap="__e">读取</view></view><divider vue-id="48dad621-2" bind:__l="__l"></divider><textarea class="item-content font-size-subtitle" disabled="true" placeholder="读取内容" value="{{readText}}"></textarea></view></block><block wx:if="{{characteristic.properties.write}}"><view class="flex flex-column h-spacing-large-top"><view class="item-bar flex flex-row justify-between align-center"><text class="font-size-list color-text-title">写入</text><view class="flex flex-row align-center"><sk-switch vue-id="48dad621-3" leftText="HEX" rightText="ASCII" value="{{formatValue}}" data-event-opts="{{[['^change',[['formatChange']]]]}}" bind:change="__e" bind:__l="__l"></sk-switch><view data-event-opts="{{[['tap',[['writeAction']]]]}}" class="item-btn v-spacing-large-left" bindtap="__e">写入</view></view></view><divider vue-id="48dad621-4" bind:__l="__l"></divider><textarea class="item-content font-size-subtitle" placeholder="写入数据" data-event-opts="{{[['input',[['writeTextVal',['$event']]]]]}}" value="{{writeText}}" bindinput="__e"></textarea></view></block></view>