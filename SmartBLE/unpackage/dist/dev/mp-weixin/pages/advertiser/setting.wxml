<view class="flex flex-column"><text class="list-title">Log Printing</text><view class="list-input flex flex-row align-center"><text class="list-input-title flex-1">打印格式</text><sk-switch vue-id="72c53601-1" leftText="HEX" rightText="ASCII" value="{{LogFormat}}" data-event-opts="{{[['^change',[['formatChange']]]]}}" bind:change="__e" bind:__l="__l"></sk-switch></view><divider vue-id="72c53601-2" bind:__l="__l"></divider><view class="list-input flex flex-row align-center"><text class="list-input-title flex-1">简化展示</text><switch color="#1677ff" checked="{{LogSimplify}}" data-event-opts="{{[['change',[['switchChange',['$event']]]]]}}" bindchange="__e"></switch></view><divider vue-id="72c53601-3" bind:__l="__l"></divider><view class="list-input flex flex-row align-center"><text class="list-input-title flex-1">自动滚动</text><switch color="#1677ff" checked="{{LogAutoRoll}}" data-event-opts="{{[['change',[['switchChange',['$event']]]]]}}" bindchange="__e"></switch></view><text class="list-title">Response Mode</text><view class="list-input flex flex-row align-center"><text class="list-input-title flex-1">响应</text><sk-switch vue-id="72c53601-4" leftText="被写入" rightText="循环" value="{{RspModel}}" data-event-opts="{{[['^change',[['modelChange']]]]}}" bind:change="__e" bind:__l="__l"></sk-switch></view><divider vue-id="72c53601-5" bind:__l="__l"></divider><block wx:if="{{RspModel}}"><view data-event-opts="{{[['tap',[['goPage']]]]}}" class="list-input flex flex-row align-center" bindtap="__e"><text class="list-input-title flex-1">循环延迟</text><text class="color-text-weak font-size-subtitle">{{RspStepExt}}</text><text class="iconfont icon-next color-text-weak font-size-stress"></text></view></block><view class="btn-content flex flex-row justify-between"><view data-event-opts="{{[['tap',[['clsAction']]]]}}" class="btn text-center color-text-title font-size-title" bindtap="__e">清屏</view><view data-event-opts="{{[['tap',[['ssAction']]]]}}" class="btn text-center color-fill-primary color-text-base font-size-title" bindtap="__e">{{''+btnTitle+''}}</view></view></view>