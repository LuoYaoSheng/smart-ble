<view class="flex flex-column"><text class="list-title">Scanner</text><view data-event-opts="{{[['tap',[['goPage']]]]}}" class="list-input flex flex-row" bindtap="__e"><text class="list-input-title flex-1">扫描间隔</text><text class="color-text-weak font-size-subtitle">{{intervalExt}}</text><text class="iconfont icon-next color-text-weak font-size-stress"></text></view><divider vue-id="0ea2ed1b-1" bind:__l="__l"></divider><view class="list-input flex flex-row"><text class="list-input-title flex-1">连接后是否停止扫描</text><switch color="#1677ff" checked="{{checked}}" data-event-opts="{{[['change',[['switchChange',['$event']]]]]}}" bindchange="__e"></switch></view><text class="list-title">Application</text><view class="list-input flex flex-row"><text class="list-input-title flex-1">版本号</text><text class="color-text-weak font-size-subtitle">{{"V "+version}}</text></view><divider vue-id="0ea2ed1b-2" bind:__l="__l"></divider><view data-event-opts="{{[['tap',[['goUrl',['$0'],['GitHubUrl']]]]]}}" class="list-input flex flex-row" bindtap="__e"><text class="list-input-title flex-1">GitHub</text><text class="iconfont icon-next color-text-weak font-size-stress"></text></view><text class="list-title">About</text><view data-event-opts="{{[['tap',[['goUrl',['$0'],['FeedbackUrl']]]]]}}" class="list-input flex flex-row" bindtap="__e"><text class="list-input-title flex-1">提交反馈</text><text class="iconfont icon-next color-text-weak font-size-stress"></text></view><divider vue-id="0ea2ed1b-3" bind:__l="__l"></divider><view data-event-opts="{{[['tap',[['goAbout']]]]}}" class="list-input flex flex-row" bindtap="__e"><text class="list-input-title flex-1">关于我们</text><text class="iconfont icon-next color-text-weak font-size-stress"></text></view><divider vue-id="0ea2ed1b-4" bind:__l="__l"></divider><view data-event-opts="{{[['tap',[['goUrl',['$0'],['PrivacyPolicyUrl']]]]]}}" class="list-input flex flex-row" bindtap="__e"><text class="list-input-title flex-1">隐私政策</text><text class="iconfont icon-next color-text-weak font-size-stress"></text></view></view>