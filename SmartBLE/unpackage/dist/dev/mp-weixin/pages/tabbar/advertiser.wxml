<block wx:if="{{!isMp}}"><view class="flex flex-column"><text class="list-title">Service</text><view class="list-input flex flex-row"><text class="list-input-title">服务UUID</text><input class="list-input-value flex-1" type="text" placeholder="请输入服务UUID" value="{{Service.uuid}}"/></view><text class="list-title">Characteristic</text><view class="list-input flex flex-row"><text class="list-input-title">服务UUID</text><input class="list-input-value flex-1" type="text" placeholder="请输入服务UUID" value="{{Characteristic.uuid1}}"/></view><divider vue-id="d1cb15da-1" bind:__l="__l"></divider><view class="list-input flex flex-row"><text class="list-input-title">特征UUID</text><input class="list-input-value flex-1" type="text" placeholder="请输入特征UUID" value="{{Characteristic.uuid2}}"/></view><divider vue-id="d1cb15da-2" bind:__l="__l"></divider><view class="list-input flex flex-row"><text class="list-input-title">特征数据</text><input class="list-input-value flex-1" type="text" placeholder="请输入特征数据" value="{{Characteristic.data1}}"/></view><divider vue-id="d1cb15da-3" bind:__l="__l"></divider><view class="list-input flex flex-row"><text class="list-input-title">通知数据</text><input class="list-input-value flex-1" type="text" placeholder="请输入通知数据" value="{{Characteristic.data2}}"/></view><button data-event-opts="{{[['tap',[['btnAction']]]]}}" class="btn v-spacing-large corner-radius-md font-size-title" bindtap="__e">开始广播</button></view></block><block wx:else><view class="flex flex-column"><text class="list-title">Service</text><view class="list-input flex flex-row"><text class="list-input-title">服务名称</text><input class="list-input-value flex-1" type="text" placeholder="请输入服务名称" data-event-opts="{{[['input',[['nameVal',['$event']]]]]}}" value="{{Service.name}}" bindinput="__e"/></view><button class="btn v-spacing-large corner-radius-md font-size-title" loading="{{serverState}}" data-event-opts="{{[['tap',[['btnAction']]]]}}" bindtap="__e">{{btnTitle}}</button></view></block>