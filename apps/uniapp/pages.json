{
	"pages": [
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "BLE Toolkit+",
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/device/detail",
			"style": {
				"navigationBarTitleText": "设备详情",
				"navigationBarTextStyle": "black"
			}
		},
		{
			"path": "pages/broadcast/index",
			"style": {
				"navigationBarTitleText": "BLE广播",
				"navigationBarBackgroundColor": "#ffffff",
				"navigationBarTextStyle": "black"
			}
		},
		{
			"path": "pages/about/index",
			"style": {
				"navigationBarTitleText": "关于",
				"navigationBarTextStyle": "black",
				"navigationBarBackgroundColor": "#FFFFFF"
			}
		},
		{
			"path": "pages/about/version",
			"style": {
				"navigationBarTitleText": "版本记录",
				"navigationBarTextStyle": "black",
				"navigationBarBackgroundColor": "#FFFFFF"
			}
		}
	],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "uni-app",
		"navigationBarBackgroundColor": "#F8F8F8",
		"backgroundColor": "#F8F8F8"
	},
	"uniIdRouter": {},
	"easycom": {
		"autoscan": true,
		"custom": {
			"^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue",
			"^fui-(.*)": "@/components/firstui/fui-$1/fui-$1.vue"
		}
	},
	"tabBar": {
		"color": "#7A7E83",
		"selectedColor": "#007AFF",
		"backgroundColor": "#ffffff",
		"borderStyle": "black",
		"list": [
			{
				"pagePath": "pages/index/index",
				"iconPath": "static/tabs/device.png",
				"selectedIconPath": "static/tabs/device_active.png",
				"text": "设备"
			},
			{
				"pagePath": "pages/broadcast/index",
				"iconPath": "static/tabs/broadcast.png",
				"selectedIconPath": "static/tabs/broadcast_active.png",
				"text": "广播"
			},
			{
				"pagePath": "pages/about/index",
				"iconPath": "static/tabs/about.png",
				"selectedIconPath": "static/tabs/about_active.png",
				"text": "关于"
			}
		]
	}
}
