<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Colors -->
    <SolidColorBrush x:Key="Primary" Color="#007AFF"/>
    <SolidColorBrush x:Key="PrimaryDark" Color="#0051D5"/>
    <SolidColorBrush x:Key="PrimaryLight" Color="#E8F2FF"/>
    <SolidColorBrush x:Key="Success" Color="#34C759"/>
    <SolidColorBrush x:Key="SuccessLight" Color="#E8F8EE"/>
    <SolidColorBrush x:Key="Warning" Color="#FF9500"/>
    <SolidColorBrush x:Key="WarningLight" Color="#FFF5E8"/>
    <SolidColorBrush x:Key="Error" Color="#FF3B30"/>
    <SolidColorBrush x:Key="ErrorLight" Color="#FFE8E8"/>
    <SolidColorBrush x:Key="Background" Color="#F2F2F7"/>
    <SolidColorBrush x:Key="Border" Color="#E5E5EA"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#8E8E93"/>

    <!-- Button Styles -->
    <Style Selector="button.primary">
        <Setter Property="Background" Value="{DynamicResource Primary}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <Style Selector="button.primary:hover">
        <Setter Property="Background" Value="{DynamicResource PrimaryDark}"/>
    </Style>

    <Style Selector="button.primary.scanning">
        <Setter Property="Background" Value="{DynamicResource Error}"/>
    </Style>

    <Style Selector="button.secondary">
        <Setter Property="Background" Value="{DynamicResource Background}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <Style Selector="button.secondary:hover">
        <Setter Property="Background" Value="{DynamicResource Border}"/>
    </Style>

    <Style Selector="button.danger">
        <Setter Property="Background" Value="{DynamicResource Error}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="20,10"/>
        <Setter Property="CornerRadius" Value="10"/>
    </Style>

    <Style Selector="button.danger:hover">
        <Setter Property="Background" Color="#E8352A"/>
    </Style>

    <!-- DeviceCount Badge -->
    <Style Selector="border.devicecount">
        <Setter Property="Background" Value="{DynamicResource PrimaryLight}"/>
        <Setter Property="CornerRadius" Value="20"/>
    </Style>
    <Style Selector="border.devicecount textblock">
        <Setter Property="Foreground" Value="{DynamicResource Primary}"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <!-- DeviceCard -->
    <Style Selector="border.devicecard">
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="BoxShadow">
            <BoxShadow OffsetX="0" OffsetY="2" Blur="5" Color="#10000000"/>
        </Setter>
    </Style>
    <Style Selector="border.devicecard:pointerover /template/ border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BoxShadow">
            <BoxShadow OffsetX="0" OffsetY="4" Blur="12" Color="#20000000"/>
        </Setter>
    </Style>

    <!-- StatusBadge -->
    <Style Selector="border.statusbadge">
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding" Value="12,6"/>
    </Style>
    <Style Selector="border.statusbadge textblock">
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="FontSize" Value="13"/>
    </Style>

    <!-- ServiceCard -->
    <Style Selector="border.servicecard">
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Padding" Value="16"/>
        <Setter Property="BoxShadow">
            <BoxShadow OffsetX="0" OffsetY="2" Blur="5" Color="#10000000"/>
        </Setter>
    </Style>

    <!-- ServiceCount -->
    <Style Selector="border.servicecount">
        <Setter Property="Background" Value="{DynamicResource PrimaryLight}"/>
        <Setter Property="CornerRadius" Value="12"/>
    </Style>
    <Style Selector="border.servicecount textblock">
        <Setter Property="Foreground" Value="{DynamicResource Primary}"/>
        <Setter Property="FontWeight" Value="Medium"/>
    </Style>

    <!-- LogPanel -->
    <Style Selector="border.logpanel">
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="BorderBrush" Value="{DynamicResource Border}"/>
        <Setter Property="BorderThickness" Value="1,0,0,0"/>
        <Setter Property="Height" Value="150"/>
    </Style>

    <!-- Characteristic Buttons -->
    <Style Selector="button.charbutton">
        <Setter Property="Background" Value="White"/>
        <Setter Property="BorderBrush" Value="#E0E0E0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="MinWidth" Value="40"/>
    </Style>
    <Style Selector="button.charbutton:hover">
        <Setter Property="Background" Value="#F5F5F5"/>
        <Setter Property="BorderBrush" Value="#D0D0D0"/>
    </Style>
    <Style Selector="button.charbutton stackpanel">
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <!-- FilterPanel -->
    <Style Selector="border.filterpanel">
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="BoxShadow">
            <BoxShadow OffsetX="0" OffsetY="2" Blur="8" Color="#10000000"/>
        </Setter>
    </Style>

    <!-- TextButton -->
    <Style Selector="button.textbutton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="#007AFF"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="button.textbutton:pointerover">
        <Setter Property="Foreground" Value="#0051D5"/>
    </Style>

</Styles>
